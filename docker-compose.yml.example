services:
  server:
    image: nikolaik/python-nodejs:python3.10-nodejs20
    container_name: chatbot01
    working_dir: /home/chatbot_platform
    command: ["/bin/bash", "-c", "chmod +x /home/chatbot_platform/start.sh && /home/chatbot_platform/start.sh"]
    volumes:
      - ${PROJECT_ROOT:-.}:/home/chatbot_platform
    expose:
      - "3000"
      - "36100"
    restart: unless-stopped

  nginx:
    image: nginx:1.27-alpine
    container_name: chatbot-platform-nginx
    depends_on:
      - server
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ${PROJECT_ROOT:-.}/nginx/conf/default.conf:/etc/nginx/conf.d/default.conf:ro
      - ${PROJECT_ROOT:-.}/nginx/ssl:/etc/nginx/ssl:ro
    restart: unless-stopped
