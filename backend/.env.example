# ---------------------------------------------------------------------------
# 複製為 .env 後依環境修改：copy .env.example .env
# ---------------------------------------------------------------------------

# vLLM connection (OpenAI-compatible endpoint)
VLLM_BASE_URL=http://127.0.0.1:8000/v1
# 相容 OpenAI Client；多數自建 vLLM 可保留 EMPTY 或省略
VLLM_API_KEY=EMPTY
#VLLM_MODEL="Xingyu-Zheng/gemma-4-E2B-it-int4-foem"
VLLM_MODEL="Qwen/Qwen2.5-7B-Instruct-AWQ"
# 知識庫摘要用（可留空，程式會退回 VLLM_MODEL 或內建預設）
# VLLM_SUMMARY_MODEL=

# MariaDB / MySQL（與 docker-compose 預設帳密一致時可沿用）
DATABASE_URL=mysql+pymysql://chatbot_user:pass@mariadb:3306/chatbot_db

# 若仍有呼叫 OpenAI 官方 API 時再填
# OPENAI_API_KEY=

# --- 選填：RAG / 除錯（程式內有預設值，不必設定也能跑）
# RAG_TOP_K=5
# RAG_VECTOR_FETCH_K=20
# RAG_BM25_CORPUS_LIMIT=1500
# RAG_BM25_FETCH_K=20
# RAG_HYBRID_ALPHA=0.7
# LLM_PROMPT_LOG_MAX_CHARS=24000
